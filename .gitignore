# Keys: ignore EVERYTHING under keys/ (private signing key, reveal key, subject
# mapping, scrub tokens, tmp) except the public verification key. Deny-by-default so
# no future secret is ever committed by accident.
keys/*
!keys/bundle-signing.public.pem

# Aqua tooling deps (reproducible via package.json + lockfile; node_modules is heavy)
tools/aqua/node_modules/
tools/aqua/credentials.json

# OS / editor noise
.DS_Store
.obsidian/
